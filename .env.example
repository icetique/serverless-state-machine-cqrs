DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Dedicated DB for npm run test:integration — must NOT be production. Tests INSERT rows and never clean up.
# For local dev you may set this to the same URL as DATABASE_URL on a throwaway Supabase project only.
INTEGRATION_DATABASE_URL=
EVENT_PUBLISHER_MODE=local
EVENT_BUS_NAME=default
ENABLE_MANUAL_SETTLEMENT_TRIGGER=false
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
MERCHANT_EMAIL=merchant_1@example.com
MERCHANT_PASSWORD=
PARTNER_EMAIL=partner_2@example.com
PARTNER_PASSWORD=
ADMIN_EMAIL=admin_1@example.com
ADMIN_PASSWORD=
