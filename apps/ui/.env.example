# Local dev: leave VITE_API_BASE_URL unset (App.tsx defaults to /api; Vite proxies to sam local).
# Production (Vercel): set to your API Gateway base URL, e.g.
# VITE_API_BASE_URL=https://your-api.execute-api.eu-central-1.amazonaws.com/Prod
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENABLE_MANUAL_SETTLEMENT_TRIGGER=false
VITE_DEMO_MERCHANT_EMAIL=
VITE_DEMO_MERCHANT_PASSWORD=
VITE_DEMO_PARTNER_EMAIL=
VITE_DEMO_PARTNER_PASSWORD=
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=
